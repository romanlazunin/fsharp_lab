let mutable position = 1
let mutable sum_position = 0
let mutable sum = 0
for character in input do
    if character = '(' then sum <- sum + 1 
    else sum <- sum - 1

    if sum = -1 && sum_position = 0 then 
        sum_position <- position

    position <- position + 1

printfn "%d" sum_position

let intArray =
    input.ToCharArray()
    |> Array.map (fun x -> if x = '(' then 1 else -1 )

let rec sumRec (arr: int array) = 
    match arr with
    | [||] -> 0
    | x -> x[x.Length - 1] + sumRec(x[0..x.Length - 2])

printfn $"{sumRec intArray}"